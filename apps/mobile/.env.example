# 実機 (iPhone) で動かすときに必要。
# Mac のローカル LAN IP を入れてください (例: 192.168.1.42)。
# Simulator / Web では未設定で OK (localhost が使われます)。
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8787

# フォトムービーの BGM として再生する音楽ファイルの URL。
# mp3 / m4a など expo-av が対応している形式を指定してください。
# 未設定の場合は BGM なしで再生されます。
# EXPO_PUBLIC_BGM_URL=https://example.com/your-bgm.mp3

# Google ログイン用の OAuth クライアント ID。
# Google Cloud Console で iOS / Android / Web 用にそれぞれ発行して設定します。
# (Expo Go では webClientId が使われます。実機ビルドでは各プラットフォーム用が必要)
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxx-ios.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxx-android.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxx-web.apps.googleusercontent.com
