# ローカルで API を動かす際の環境変数のサンプル。
# 実際の値は apps/api/.env に書く(.env は gitignore 済み・コミットしない)。

# DB (未設定ならローカルの localhost:5432 を使う)
# DATABASE_URL=postgresql+asyncpg://todo:todo@localhost:5432/todo

# Supabase Storage (写真の保存先)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role(secret) キー。anon では Storage へのアップロード不可。
SUPABASE_KEY=eyJ... (service_role secret)
SUPABASE_BUCKET=photos

# 認証: 自前のセッショントークン(JWT)の署名鍵。32バイト以上の乱数を推奨。
# 例: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Google ログインで許容する client ID。iOS/Android/Web をカンマ区切りで設定する。
# Google Cloud Console の「OAuth クライアント ID」で発行した値。
GOOGLE_CLIENT_IDS=xxx-ios.apps.googleusercontent.com,yyy-web.apps.googleusercontent.com
